<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.controller.AddBookController">
    <children>
        <Label text="%book.add.title">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <GridPane hgap="10.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="250.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="40.0" />
            </columnConstraints>

            <children>
                <Label text="%book.title" />
                <TextField fx:id="titleField" GridPane.columnIndex="1" GridPane.columnSpan="2" />

                <Label text="%book.year" GridPane.rowIndex="1" />
                <TextField fx:id="yearField" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="1" />

                <Label text="%book.author" GridPane.rowIndex="2" />
                <ComboBox fx:id="authorCombo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Button onAction="#handleNewAuthor" text="+" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                <Label text="%book.genre" GridPane.rowIndex="3" />
                <ComboBox fx:id="genreCombo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <Button onAction="#handleNewGenre" text="+" GridPane.columnIndex="2" GridPane.rowIndex="3" />
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button onAction="#handleCancel" text="%btn.cancel" />
                <Button onAction="#handleSave" style="-fx-background-color: #2c3e50;" text="%btn.save" textFill="WHITE" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>