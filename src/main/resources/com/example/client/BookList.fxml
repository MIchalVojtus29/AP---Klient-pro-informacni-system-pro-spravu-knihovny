<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.controller.BooksController">

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="%book.search" />
        <TextField fx:id="searchField" promptText="%book.searchPrompt" HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="bookTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="%book.id" />
            <TableColumn fx:id="colTitle" prefWidth="250.0" text="%book.title" />
            <TableColumn fx:id="colAuthor" prefWidth="150.0" text="%book.author" />
            <TableColumn fx:id="colGenre" prefWidth="120.0" text="%book.genre" />
            <TableColumn fx:id="colYear" prefWidth="80.0" text="%book.year" />
            <TableColumn fx:id="colQuantity" prefWidth="80.0" text="%book.quantity" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="btnPrev" onAction="#handlePreviousPage" text="←" />
        <Label fx:id="pageLabel" text="1 / 1" style="-fx-font-weight: bold;" />
        <Button fx:id="btnNext" onAction="#handleNextPage" text="→" />
    </HBox>

    <Separator />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#handleAddBook" style="-fx-background-color: #2c3e50;" text="%book.add" textFill="WHITE" />
        <Button onAction="#handleEditBook" style="-fx-background-color: #2c3e50;" text="%book.edit" textFill="WHITE" />
        <Button onAction="#handleDeleteBook" style="-fx-background-color: #2c3e50;" text="%book.delete" textFill="WHITE" />
    </HBox>

</VBox>