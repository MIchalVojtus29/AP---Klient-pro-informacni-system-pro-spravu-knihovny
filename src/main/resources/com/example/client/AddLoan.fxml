<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" style="-fx-padding: 25;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.controller.AddLoanController">

    <Label text="%loans.add.title" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane vgap="15.0" hgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="120.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="%loans.book" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="bookCombo" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="%loans.selectBook"/>

        <Label text="%loans.reader" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="readerCombo" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="%loans.selectReader"/>

        <Label text="%loans.dueDate" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="returnDatePicker" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="%btn.cancel" onAction="#handleCancel" style="-fx-background-color: #bdc3c7;" />
        <Button text="%loans.add" onAction="#handleSave" style="-fx-background-color: #2c3e50; -fx-text-fill: white;" />
    </HBox>
</VBox>