<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainLayout" prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.controller.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <Label text="%main.title" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="userNameLabel" text="User Name" textFill="WHITE" />
            <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c;" text="%main.logout" textFill="WHITE" />
        </HBox>
    </top>

    <left>
        <VBox spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-padding: 15;" prefWidth="150.0">
            <Button maxWidth="Infinity" text="%menu.catalog" onAction="#handleShowBooks" />
            <Button maxWidth="Infinity" text="%menu.loans" onAction="#handleShowLoans"/>
            <Button maxWidth="Infinity" text="%menu.users" onAction="#handleShowUsers" />
            <Region VBox.vgrow="ALWAYS" />

            <Separator />
            <Button fx:id="btnLang" maxWidth="Infinity" onAction="#handleLanguageSwitch" text="%btn.switchLang" />
        </VBox>
    </left>

    <center>
    </center>
</BorderPane>