<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" style="-fx-padding: 25;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.controller.EditUserController">

    <Label text="%user.edit.title" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane vgap="15.0" hgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="%users.firstName" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="%users.lastName" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="lastNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="%users.email" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="%users.phone" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="%users.role" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="roleCombo" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="%user.password" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <PasswordField fx:id="passwordField" promptText="Ponechte prázdné pro zachování hesla" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="%btn.cancel" onAction="#handleCancel" style="-fx-background-color: #bdc3c7; -fx-text-fill: black;" />
        <Button text="%btn.save" onAction="#handleSave" style="-fx-background-color: #2c3e50; -fx-text-fill: white;" />
    </HBox>
</VBox>