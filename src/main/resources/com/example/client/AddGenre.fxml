<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.controller.AddGenreController">
    <children>
        <Label text="%genre.add.title">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <GridPane hgap="10.0" vgap="10.0">
            <children>
                <Label text="%genre.name" />
                <TextField fx:id="nameField" GridPane.columnIndex="1" />
            </children>
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button onAction="#handleCancel" text="%btn.cancel" />
                <Button onAction="#handleSave" style="-fx-background-color: #2c3e50;" text="%btn.save" textFill="WHITE" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>