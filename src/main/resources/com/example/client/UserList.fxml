<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.controller.UsersController">

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="%users.search.prompt" />
        <TextField fx:id="searchField" promptText="%users.search.prompt" HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colFirstName" prefWidth="150.0" text="%users.firstName" />
            <TableColumn fx:id="colLastName" prefWidth="150.0" text="%users.lastName" />
            <TableColumn fx:id="colEmail" prefWidth="200.0" text="%users.email" />
            <TableColumn fx:id="colRole" prefWidth="100.0" text="%users.role" />
            <TableColumn fx:id="colPhoneNumber" prefWidth="150.0" text="%users.phone" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="btnPrev" onAction="#handlePreviousPage" text="←" />
        <Label fx:id="pageLabel" text="1 / 1" style="-fx-font-weight: bold;" />
        <Button fx:id="btnNext" onAction="#handleNextPage" text="→" />
    </HBox>

    <Separator />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#handleAddUser" style="-fx-background-color: #2c3e50;" text="%btn.add" textFill="WHITE" />
        <Button onAction="#handleEditUser" style="-fx-background-color: #2c3e50;" text="%btn.edit" textFill="WHITE" />
        <Button onAction="#handleDeleteUser" style="-fx-background-color: #2c3e50;" text="%btn.delete" textFill="WHITE" />
    </HBox>

</VBox>